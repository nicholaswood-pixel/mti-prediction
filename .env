AWS_REGION=us-east-1
PROJECT_NAME=mti-score

# GitHub source (default mode)
GITHUB_OWNER=nicholaswood-pixel
GITHUB_REPO=mti-prediction
GITHUB_BRANCH=main
GITHUB_CONNECTION_ARN=arn:aws:codeconnections:us-east-1:799139197310:connection/08dd6923-fb83-42e2-8fb0-bbfc3d559460

SAGEMAKER_PIPELINE_ROLE_NAME=AmazonSageMakerServiceCatalogProductsExecutionRole
CODEBUILD_ROLE_NAME=AmazonSageMakerServiceCatalogProductsCodeBuildRole
CODEPIPELINE_ROLE_NAME=AmazonSageMakerServiceCatalogProductsCodePipelineRole

# Optional: push template files to remote GitHub repo after connection check and before infra provisioning
PUSH_TEMPLATE_TO_REMOTE=true

# Optional: existing MLflow tracking server (e.g. SageMaker Studio tracking server ARN, or https://...).
# CodeBuild/run-pipeline logs a summary run when MLFLOW_TRACKING_URI is set. Match client to server version.
MLFLOW_TRACKING_URI=arn:aws:sagemaker:us-east-1:799139197310:mlflow-tracking-server/mti-score-prediction
MLFLOW_PYTHON_CLIENT_VERSION=3.0.0.dev0
MLFLOW_EXPERIMENT_NAME=mti-score-prediction